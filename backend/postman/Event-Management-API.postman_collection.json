{
  "info": {
    "name": "Event Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"student@test.lk\",\n  \"password\": \"secret12\",\n  \"confirmPassword\": \"secret12\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@test.lk\",\n  \"password\": \"secret12\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Forgot password (email link)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@test.lk\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/forgot-password"
          }
        },
        {
          "name": "Reset password with token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"newsecret12\",\n  \"confirmPassword\": \"newsecret12\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/reset-password/REPLACE_WITH_TOKEN_FROM_EMAIL"
          }
        }
      ]
    },
    {
      "name": "Users (Bearer)",
      "item": [
        {
          "name": "Get profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/profile"
          }
        },
        {
          "name": "Update profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}"
            },
            "url": "{{baseUrl}}/api/users/profile"
          }
        }
      ]
    },
    {
      "name": "Feedback (Bearer)",
      "item": [
        {
          "name": "Submit feedback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"EVENT_OBJECT_ID\",\n  \"rating\": 5,\n  \"comment\": \"Great event\"\n}"
            },
            "url": "{{baseUrl}}/api/feedback"
          }
        },
        {
          "name": "Feedback by event",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/feedback/event/{{eventId}}"
          }
        },
        {
          "name": "My feedback",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/feedback/my"
          }
        }
      ]
    }
  ]
}
